# VestPrimer Frontend — Environment Variables
# Zkopíruj do .env.local a vyplň hodnoty

# URL backendu (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000

# API klíč pro autentizaci — musí se shodovat s PARTNER_API_KEY na serveru
NEXT_PUBLIC_PARTNER_KEY=

# Zapne God Mode (debug funkce) — NIKDY nenastavovat na true v produkci
NEXT_PUBLIC_DEV_MODE=false
